generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  role      Role      @default(dev)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chamados  Chamado[]

  @@map("users")
}

model Chamado {
  id        String        @id @default(uuid())
  nome      String
  cliente   String
  usuarioId String
  status    ChamadoStatus @default(aberto)
  dtInicio  DateTime      @default(now())
  dtFim     DateTime?
  valor     Float         @default(0)
  usuario   User          @relation(fields: [usuarioId], references: [id])
  tarefas   Tarefa[]

  @@map("chamados")
}

model Tarefa {
  id        String       @id @default(uuid())
  chamadoId String
  descricao String
  dtInicio  DateTime     @default(now())
  dtFim     DateTime?
  status    TarefaStatus @default(aberto)
  chamado   Chamado      @relation(fields: [chamadoId], references: [id], onDelete: Cascade)

  @@map("tarefas")
}

enum Role {
  admin
  dev
}

enum ChamadoStatus {
  aberto
  finalizado
}

enum TarefaStatus {
  aberto
  fechado
}
