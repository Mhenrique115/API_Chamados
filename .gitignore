# ───────────────────────────────
#  Node
# ───────────────────────────────
node_modules/
dist/

# ───────────────────────────────
#  Ambiente
# ───────────────────────────────
.env
.env.local
.env.*.local

# ───────────────────────────────
#  Prisma
# ───────────────────────────────
node_modules/.prisma/
src/generated/

# ───────────────────────────────
#  Logs
# ───────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────
#  TypeScript
# ───────────────────────────────
*.tsbuildinfo

# ───────────────────────────────
#  Sistema Operacional
# ───────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ───────────────────────────────
#  Editores / IDEs
# ───────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# ───────────────────────────────
#  Miscelânea
# ───────────────────────────────
*.zip
*.tar.gz
*.bak
*.tmp
coverage/
.nyc_output/