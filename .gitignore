# ============================================================
#  HelpDesk — .gitignore
# ============================================================

# ───────────────────────────────
#  Node / Backend
# ───────────────────────────────
node_modules/
backend/node_modules/
backend/dist/
backend/.env
backend/.env.local
backend/.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────
#  Prisma
# ───────────────────────────────
# Manter schema.prisma e migrations, ignorar só o client gerado
backend/node_modules/.prisma/
backend/src/generated/

# ───────────────────────────────
#  Frontend
# ───────────────────────────────
# Sem build no frontend (Vanilla JS puro), nada a ignorar
# exceto se usar bundler futuramente:
frontend/dist/
frontend/.parcel-cache/

# ───────────────────────────────
#  Sistema Operacional
# ───────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ───────────────────────────────
#  Editores / IDEs
# ───────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates
*.sublime-project
*.sublime-workspace

# ───────────────────────────────
#  TypeScript
# ───────────────────────────────
*.tsbuildinfo

# ───────────────────────────────
#  Testes (se adicionar futuramente)
# ───────────────────────────────
coverage/
.nyc_output/

# ───────────────────────────────
#  Miscelânea
# ───────────────────────────────
*.zip
*.tar.gz
*.bak
*.tmp